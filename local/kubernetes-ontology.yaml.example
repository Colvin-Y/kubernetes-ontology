# Copy to local/kubernetes-ontology.yaml and edit for your machine.
# local/*.yaml is ignored by git.

kubeconfig: /absolute/path/to/kubeconfig.yaml
cluster: kind-kind

# Default namespace for CLI filters and diagnostic entrypoints.
namespace: default

# Namespaces collected by the server. Empty list means all namespaces.
contextNamespaces:
  - default
  - kube-system

# Custom workload-like resources to collect with the Kubernetes dynamic client.
# This lets ownerReference chains resolve through CRDs such as Kruise ASTS and
# domain operators such as RedisCluster.
# These example CRDs are optional: on a clean kind cluster they are logged and
# skipped by informer setup until the CRDs are installed or the entries removed.
workloadResources:
  - group: apps.kruise.io
    version: v1beta1
    resource: statefulsets
    kind: StatefulSet
    namespaced: true
  - group: redis.io
    version: v1beta1
    resource: clusters
    kind: Cluster
    namespaced: true

# Display-only controller ownership rules that Kubernetes does not expose
# through ownerReferences. apiVersion supports exact values and group wildcards.
controllerRules:
  - apiVersion: apps.kruise.io/*
    kind: "*"
    namespace: kruise-system
    controllerPodPrefixes:
      - kruise-controller-manager
    nodeDaemonPodPrefixes:
      - kruise-daemon

# CSI component inference rules. Add each cluster-specific CSI driver that
# should be linked to its controller and node-agent Pods.
csiComponentRules:
  - driver: local.csi.aliyun.com
    namespace: kube-system
    controllerPodPrefixes:
      - open-local-controller-
      - open-local-scheduler-
    nodeAgentPodPrefixes:
      - open-local-agent-
  - driver: bytedrive.csi.bytedance.com
    namespace: bd-csi
    controllerPodPrefixes:
      - csi-bytedrive-snapshotter-
      - csi-resizer-
      - snapshot-controller-
      - bd-provisioner-
    nodeAgentPodPrefixes:
      - bd-registrar-
      - bd-csidaemon-
      - bd-csi-

server:
  addr: 127.0.0.1:18080
  url: http://127.0.0.1:18080

bootstrapTimeout: 2m
streamMode: informer
pollInterval: 5s
observeDuration: 40s
maxDepth: 2
storageMaxDepth: 5
